[Unit]
Description=AI Voice Assistant Web UI
After=network.target voice-assistant.service

[Service]
Type=simple
User=chyiyaqing
WorkingDirectory=/home/chyiyaqing/chyi/voice-kit
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/chyiyaqing/chyi/voice-kit/.venv/bin/uvicorn web_server:app --host 0.0.0.0 --port 8080
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
