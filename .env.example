# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── LLM provider ─────────────────────────────────────────────────────────────
# "ollama" (local/self-hosted), "deepseek" (DeepSeek cloud API), or "claude" (Anthropic)
LLM_PROVIDER=ollama

# ─── Anthropic Claude API ────────────────────────────────────────────────────
# Required when LLM_PROVIDER=claude
#
# Auth method 1 (recommended): OAuth token
#   cp credentials/auth-profiles.json.example credentials/auth-profiles.json
#   Fill in your OAuth token (sk-ant-oau04-...) in credentials/auth-profiles.json
#   The credentials/ directory is gitignored — never commit real tokens.
#
# Auth method 2 (fallback): API key from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Path to OAuth credentials file (default: ./credentials/auth-profiles.json)
# ANTHROPIC_OAUTH_CREDENTIALS=./credentials/auth-profiles.json
# Model ID (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6
# Max tokens in response (voice replies should stay short)
ANTHROPIC_MAX_TOKENS=256

# ─── DeepSeek API ─────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# deepseek-chat (DeepSeek-V3) or deepseek-reasoner (DeepSeek-R1)
DEEPSEEK_MODEL=deepseek-chat
# Max generated tokens for voice replies
DEEPSEEK_MAX_TOKENS=256

# ─── Ollama LLM ──────────────────────────────────────────────────────────────
# Base URL of your Ollama server
OLLAMA_HOST=https://your-ollama-host.com

# Model to use. Available on this server: gemma3:4b, gemma3:12b, deepseek-r1:7b, qwen3:latest
# Larger models give better answers but are slower.
OLLAMA_MODEL=gemma3:4b

# HTTP Basic Auth credentials (leave blank if your server has no auth)
OLLAMA_USERNAME=your_username
OLLAMA_PASSWORD=your_password

# Request timeout in seconds. Increase if using a large/slow model.
OLLAMA_TIMEOUT=60

# Keep Ollama model resident after a request to avoid cold-start latency.
OLLAMA_KEEP_ALIVE=30m

# Voice replies should stay short; lower values reduce long-generation time.
OLLAMA_NUM_PREDICT=160

# HTTP streaming read chunk size. 1 minimizes token buffering latency.
LLM_STREAM_CHUNK_SIZE=1

# Rough character budget for recent chat history sent to the LLM.
LLM_CONTEXT_MAX_CHARS=12000

# ─── Local TTS ───────────────────────────────────────────────────────────────
# "piper" is more natural; "espeak" is faster and very mechanical.
TTS_ENGINE=piper
PIPER_BIN=./.venv/bin/piper
PIPER_MODEL=./models/piper/zh_CN-huayan-x_low.onnx
PIPER_CONFIG=./models/piper/zh_CN-huayan-x_low.onnx.json
PIPER_VOLUME=0.2

# espeak-ng fallback settings. Amplitude 20 means roughly 20% volume.
LOCAL_TTS_VOICE=cmn

# Approximate words per minute. Lower is slower, higher is faster.
LOCAL_TTS_SPEED=175

# Amplitude, 0-200. AIY speaker is loud; tune down if needed.
LOCAL_TTS_AMPLITUDE=20

# Start TTS before full sentence-ending punctuation if the LLM is verbose.
TTS_FIRST_CHUNK_CHARS=18
TTS_CHUNK_CHARS=36

# ─── GPIO (AIY Voice Kit V1) ─────────────────────────────────────────────────
# BCM pin numbers. Only change if using different hardware.
BUTTON_PIN=23
LED_PIN=25

# ─── Memory / Persistence ────────────────────────────────────────────────────
# Enable persistent memory system (conversation history + long-term memory)
MEMORY_ENABLED=true

# Directory to store memory files (MEMORY.md, history.jsonl)
MEMORY_DIR=./memory

# Maximum messages to load from history at startup (Pi 3B: stay conservative)
MAX_HISTORY_MESSAGES=50

# History file rotation threshold (lines). Rotates to .backup when exceeded.
HISTORY_ROTATION_THRESHOLD=2000

# Marker for LLM to trigger memory updates (advanced users only)
MEMORY_UPDATE_MARKER=[UPDATE_MEMORY]

# ─── Bootstrap System (OpenClaw-inspired) ────────────────────────────────────
# Enable Bootstrap injection system (SOUL.md, IDENTITY.md, USER.md)
BOOTSTRAP_ENABLED=true

# Max characters per Bootstrap file (prevent context overflow)
BOOTSTRAP_MAX_CHARS=20000

# Total max characters for all Bootstrap files combined
BOOTSTRAP_TOTAL_MAX_CHARS=150000

# Markers for LLM to update Bootstrap files (advanced users only)
SOUL_UPDATE_MARKER=[UPDATE_SOUL]
IDENTITY_UPDATE_MARKER=[UPDATE_IDENTITY]
USER_UPDATE_MARKER=[UPDATE_USER]
