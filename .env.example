# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── LLM provider ─────────────────────────────────────────────────────────────
# "ollama" (local/self-hosted) or "deepseek" (DeepSeek cloud API)
LLM_PROVIDER=ollama

# ─── DeepSeek API ─────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# deepseek-chat (DeepSeek-V3) or deepseek-reasoner (DeepSeek-R1)
DEEPSEEK_MODEL=deepseek-chat

# ─── Ollama LLM ──────────────────────────────────────────────────────────────
# Base URL of your Ollama server
OLLAMA_HOST=https://your-ollama-host.com

# Model to use. Available on this server: gemma3:4b, gemma3:12b, deepseek-r1:7b, qwen3:latest
# Larger models give better answers but are slower.
OLLAMA_MODEL=gemma3:4b

# HTTP Basic Auth credentials (leave blank if your server has no auth)
OLLAMA_USERNAME=your_username
OLLAMA_PASSWORD=your_password

# Request timeout in seconds. Increase if using a large/slow model.
OLLAMA_TIMEOUT=60

# ─── TTS (edge-tts — Microsoft neural voices) ────────────────────────────────
# Voice name. Examples:
#   Chinese female: zh-CN-XiaoxiaoNeural, zh-CN-XiaochenNeural, zh-CN-XiaohanNeural
#   Chinese male:   zh-CN-YunxiNeural
#   English female: en-US-JennyNeural
#   English male:   en-US-GuyNeural
# Full list: edge-tts --list-voices
TTS_VOICE=zh-CN-XiaoxiaoNeural

# Speaking rate offset. 0% = default. "+20%" faster, "-20%" slower.
TTS_RATE=+0%

# Volume offset. 0% = default. "-50%" quieter, "+20%" louder.
# Note: AIY Voice Kit speaker is loud; -70% to -90% is typically comfortable.
TTS_VOLUME=-90%

# ─── GPIO (AIY Voice Kit V1) ─────────────────────────────────────────────────
# BCM pin numbers. Only change if using different hardware.
BUTTON_PIN=23
LED_PIN=25
